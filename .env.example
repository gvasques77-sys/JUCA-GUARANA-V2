# ==============================================
# CLINICORE — Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o arquivo .env no git.

# ── OpenAI ─────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ── Supabase ────────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Servidor ────────────────────────────────────
PORT=3000
DEBUG=false

# ── Agente ──────────────────────────────────────
AGENT_MAX_STEPS=5
AGENT_TIMEOUT_MS=12000

# ── Guard Rails + State Machine ──────────────────
# Timeout de sessão de agendamento em andamento (horas)
SESSION_TIMEOUT_HOURS=4
# Gerar resumo comprimido a cada N mensagens (memória longa)
SUMMARY_TRIGGER_MESSAGES=10
# Salvar decisões do interceptor no Supabase (agent_decision_logs)
ENABLE_AGENT_DECISION_LOGS=true

# ── Clínica padrão (desenvolvimento) ────────────
# UUID de uma clínica real no banco para testes locais
DEFAULT_CLINIC_ID=

# ── Autenticação Admin ───────────────────────────
# OBRIGATÓRIO em produção — sem valor padrão por segurança
# Mínimo 12 caracteres, use uma senha forte
ADMIN_PASSWORD=

# ── Autenticação do /process (chamado pelo n8n/WhatsApp) ──
# Token compartilhado entre este serviço e o n8n
# Gere com: openssl rand -hex 32
AGENT_API_KEY=

# ── Backoffice GV AUTOMAÇÕES (F8A) ─────────────────────
# JWT exclusivo para o backoffice GV (separado do Supabase Auth das clínicas)
# OBRIGATÓRIO — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Mínimo 64 caracteres aleatórios
ADMIN_JWT_SECRET=

# ── Sentry (Sprint 0 — Observabilidade) ──────────────────
# preencher quando conta Sentry estiver criada (ação M3 do Gabriel)
# DSN formato: https://xxx@xxx.ingest.sentry.io/xxx
# Se vazio, Sentry fica desativado (nenhum erro é enviado).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
